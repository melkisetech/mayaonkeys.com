---
layout: base.njk
title: Songs
permalink: /songs/
---

{# ── Page header ───────────────────────────────────────── #}
<section class="bg-gradient-to-br from-brand-teal-50 to-brand-cream py-12 px-4 sm:px-6 text-center">
  <div class="max-w-2xl mx-auto">
    <p class="text-4xl mb-3" aria-hidden="true">🎵</p>
    <h1 class="font-display font-extrabold text-3xl sm:text-4xl text-brand-purple-700 mb-3">
      Songs I Can Play
    </h1>
    <p class="text-brand-dark/60 text-base sm:text-lg">
      {{ songs.songs | learnedSongs | length }} learned · {{ songs.songs | length - (songs.songs | learnedSongs | length) }} in progress
    </p>
  </div>
</section>

{# ── Filter legend ─────────────────────────────────────── #}
<section class="max-w-3xl mx-auto px-4 sm:px-6 mt-10">
  <div class="flex items-center gap-4 text-sm mb-6 flex-wrap">
    <span class="text-brand-dark/60 font-medium">Status:</span>
    <span class="badge-learned">✓ Learned</span>
    <span class="badge-learning">Learning</span>
  </div>

  {# ── All songs grid ──────────────────────────────────── #}
  {% set learnedList   = [] %}
  {% set learningList  = [] %}

  {% for s in songs.songs %}
    {% if s.status == "learned" %}
      {% set learnedList  = (learnedList.push(s), learnedList) %}
    {% else %}
      {% set learningList = (learningList.push(s), learningList) %}
    {% endif %}
  {% endfor %}

  {# Currently learning #}
  {% if learningList.length %}
    <h2 class="section-title mt-2">Currently Learning</h2>
    <p class="section-subtitle">Almost there!</p>
    <div class="grid sm:grid-cols-2 gap-3 mb-10">
      {% for song in learningList %}
        {% include "song-card.njk" %}
      {% endfor %}
    </div>
  {% endif %}

  {# Learned songs #}
  {% if learnedList.length %}
    <h2 class="section-title">Learned Songs</h2>
    <p class="section-subtitle">{{ learnedList.length }} song{% if learnedList.length != 1 %}s{% endif %} mastered 🎉</p>
    <div class="grid sm:grid-cols-2 gap-3">
      {% for song in learnedList %}
        {% include "song-card.njk" %}
      {% endfor %}
    </div>
  {% endif %}

  {% if not songs.songs.length %}
    <p class="text-brand-dark/50 text-sm italic py-8 text-center">No songs added yet — check back soon!</p>
  {% endif %}
</section>

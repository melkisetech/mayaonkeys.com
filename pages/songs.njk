---
layout: base.njk
title: Songs
permalink: /songs/
---

{# ── Page header ───────────────────────────────────────── #}
{% set learnedCount  = collections.songs | learnedSongs | length %}
{% set learningCount = collections.songs | length - learnedCount %}

<section class="bg-gradient-to-br from-brand-teal-50 to-brand-cream py-12 px-4 sm:px-6 text-center">
  <div class="max-w-2xl mx-auto">
    <p class="text-4xl mb-3" aria-hidden="true">🎵</p>
    <h1 class="font-display font-extrabold text-3xl sm:text-4xl text-brand-purple-700 mb-3">
      Songs I Can Play
    </h1>
    <p class="text-brand-dark/60 text-base sm:text-lg">
      {{ learnedCount }} learned · {{ learningCount }} in progress
    </p>
  </div>
</section>

<section class="max-w-3xl mx-auto px-4 sm:px-6 mt-10 mb-10">

  {# ── Currently Learning ───────────────────────────────── #}
  {% set learningList = [] %}
  {% for s in collections.songs %}
    {% if s.data.status == "learning" %}
      {% set learningList = (learningList.push(s), learningList) %}
    {% endif %}
  {% endfor %}

  {% if learningList.length %}
    <h2 class="section-title mt-2">Currently Learning</h2>
    <p class="section-subtitle">Almost there!</p>
    <div class="grid sm:grid-cols-2 gap-3 mb-12">
      {% for song in learningList %}
        {% include "song-card.njk" %}
      {% endfor %}
    </div>
  {% endif %}

  {# ── Learned Songs — by year ──────────────────────────── #}
  {% set yearGroups = collections.songs | learnedByYear %}

  {% if yearGroups.length %}
    <h2 class="section-title">Learned Songs</h2>
    <p class="section-subtitle">{{ learnedCount }} song{% if learnedCount != 1 %}s{% endif %} mastered 🎉</p>
    <ul class="mt-6 space-y-3 list-none">
      {% for group in yearGroups %}
        <li>
          <a href="/songs/{{ group.year }}/"
             class="flex items-center justify-between px-5 py-4 card hover:border-brand-teal-300 transition-colors group">
            <span class="font-display font-bold text-brand-dark text-lg group-hover:text-brand-purple-700 transition-colors">
              {{ group.year }}
            </span>
            <span class="text-sm text-brand-dark/50">
              {{ group.count }} song{% if group.count != 1 %}s{% endif %} <span aria-hidden="true" class="ml-1 text-brand-teal-400">→</span>
            </span>
          </a>
        </li>
      {% endfor %}
    </ul>
  {% endif %}

  {% if not collections.songs.length %}
    <p class="text-brand-dark/50 text-sm italic py-8 text-center">No songs added yet — check back soon!</p>
  {% endif %}

</section>

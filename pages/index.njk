---
layout: base.njk
title: Home
permalink: /
---

{# ── Hero ───────────────────────────────────────────── #}
<section class="bg-gradient-to-br from-brand-purple-50 via-brand-cream to-brand-teal-50 py-16 sm:py-20 px-4 sm:px-6 text-center">
  <div class="max-w-2xl mx-auto">
    <p class="text-5xl mb-4" aria-hidden="true">🎹</p>
    <h1 class="font-display font-extrabold text-4xl sm:text-5xl text-brand-purple-700 leading-tight mb-4">
      Maya's Piano Journey
    </h1>
    <p class="text-brand-dark/65 text-lg sm:text-xl leading-relaxed max-w-xl mx-auto">
      Follow along as Maya learns to play, one song at a time.
      A family archive of musical milestones and magic moments.
    </p>
    <div class="mt-8 flex flex-wrap gap-3 justify-center">
      <a href="/milestones/" class="btn-primary">See milestones</a>
      <a href="/songs/"      class="btn-secondary">Songs list</a>
    </div>
  </div>
</section>

{# ── Stats banner ──────────────────────────────────────── #}
<section class="max-w-3xl mx-auto px-4 sm:px-6 -mt-6 relative z-10">
  {% include "stats-banner.njk" %}
</section>

{# ── Recent milestones preview ─────────────────────────── #}
<section class="max-w-3xl mx-auto px-4 sm:px-6 mt-14">
  <div class="flex items-end justify-between mb-6">
    <div>
      <h2 class="section-title">Recent Milestones</h2>
      <p class="section-subtitle">Latest highlights from the practice room</p>
    </div>
    <a href="/milestones/" aria-label="See all milestones" class="text-sm font-semibold text-brand-teal-400 hover:text-brand-teal-500 transition-colors shrink-0 mb-6">
      See all <span aria-hidden="true">→</span>
    </a>
  </div>

  {% set recentMilestones = collections.milestones | limit(3) %}
  {% if recentMilestones.length %}
    <div class="space-y-4">
      {% for milestone in recentMilestones %}
        <article class="card flex gap-3">
          <div class="flex-1 min-w-0">
            <time class="text-xs font-semibold text-brand-teal-400 uppercase tracking-wide"
                  datetime="{{ milestone.date | htmlDateString }}">
              {{ milestone.date | dateDisplay }}
            </time>
            <h3 class="font-display font-bold text-brand-dark text-base mt-1 mb-1">{{ milestone.data.title }}</h3>
            <div class="text-sm text-brand-dark/65 line-clamp-2 prose prose-sm max-w-none
                        prose-a:text-brand-teal-400 prose-a:no-underline">
              {{ milestone.content | safe }}
            </div>
          </div>
          {% if milestone.data.image %}
            <img
              src="{{ milestone.data.image }}"
              alt="{{ milestone.data.imageAlt if milestone.data.imageAlt else milestone.data.title }}"
              class="shrink-0 w-16 h-16 rounded-lg object-cover self-start"
              loading="lazy">
          {% endif %}
        </article>
      {% endfor %}
    </div>
  {% else %}
    <p class="text-brand-dark/50 text-sm italic">No milestones yet — check back soon!</p>
  {% endif %}
</section>

{# ── Songs preview ─────────────────────────────────────── #}
<section class="max-w-3xl mx-auto px-4 sm:px-6 mt-14">
  <div class="flex items-end justify-between mb-6">
    <div>
      <h2 class="section-title">Songs I Can Play</h2>
      <p class="section-subtitle">A growing repertoire</p>
    </div>
    <a href="/songs/" aria-label="See full songs list" class="text-sm font-semibold text-brand-teal-400 hover:text-brand-teal-500 transition-colors shrink-0 mb-6">
      Full list <span aria-hidden="true">→</span>
    </a>
  </div>

  <div class="grid sm:grid-cols-2 gap-3">
    {% for song in collections.songs | learnedSongs | limit(4) %}
      {% include "song-card.njk" %}
    {% endfor %}
  </div>
</section>

{# ── Instagram banner ──────────────────────────────────── #}
<section class="max-w-3xl mx-auto px-4 sm:px-6 mt-14 mb-4">
  <a href="{{ config.instagramUrl }}"
     target="_blank"
     rel="noopener noreferrer"
     class="block bg-gradient-to-r from-brand-purple-500 to-brand-teal-400 rounded-2xl px-6 py-8 text-center text-white group hover:shadow-lg transition-shadow">
    <p class="text-3xl mb-2" aria-hidden="true">📸</p>
    <h2 class="font-display font-bold text-xl mb-1">Follow on Instagram</h2>
    <p class="text-white/80 text-sm">Watch Maya's performance videos at <span class="font-semibold">@{{ config.instagramHandle }}</span></p>
    <span class="inline-block mt-4 border border-white/60 text-white text-sm font-semibold px-5 py-1.5 rounded-full group-hover:bg-white/20 transition-colors">
      Open Instagram →
    </span>
  </a>
</section>

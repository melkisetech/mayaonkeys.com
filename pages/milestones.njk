---
layout: base.njk
title: Milestones
permalink: /milestones/
---

{# ── Page header ───────────────────────────────────────── #}
<section class="bg-gradient-to-br from-brand-purple-50 to-brand-cream py-12 px-4 sm:px-6 text-center">
  <div class="max-w-2xl mx-auto">
    <p class="text-4xl mb-3" aria-hidden="true">🏆</p>
    <h1 class="font-display font-extrabold text-3xl sm:text-4xl text-brand-purple-700 mb-3">
      Milestones
    </h1>
    <p class="text-brand-dark/60 text-base sm:text-lg">
      {{ collections.milestones.length }} moment{% if collections.milestones.length != 1 %}s{% endif %} documented so far
    </p>
  </div>
</section>

{# ── Timeline ──────────────────────────────────────────── #}
<section class="max-w-2xl mx-auto px-4 sm:px-6 mt-12 mb-6">
  {% if collections.milestones.length %}
    <div role="list" aria-label="Milestone timeline">
      {% for milestone in collections.milestones %}
        {% include "milestone-entry.njk" %}
      {% endfor %}
    </div>
  {% else %}
    <div class="text-center py-16">
      <p class="text-5xl mb-4" aria-hidden="true">🌱</p>
      <p class="text-brand-dark/50 text-base">No milestones yet — the journey is just beginning!</p>
    </div>
  {% endif %}
</section>

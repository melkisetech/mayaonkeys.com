---
layout: base.njk
title: Videos
permalink: /videos/
---

{# ── Page header ───────────────────────────────────────── #}
<section class="py-12 px-4 sm:px-6 text-center">
  <div class="max-w-2xl mx-auto">
    <p class="text-4xl mb-3" aria-hidden="true">🎬</p>
    <h1 class="font-display font-extrabold text-3xl sm:text-4xl text-brand-purple-700 mb-3">
      Videos
    </h1>
    <p class="text-brand-dark/60 text-base sm:text-lg">
      Watch Maya play — all videos live on Instagram
    </p>
  </div>
</section>

{# ── LightWidget embed ─────────────────────────────────── #}
<section class="max-w-4xl mx-auto px-4 sm:px-6 mt-10 mb-6">
  {% if config.lightwidgetEmbedCode %}
    {# Note: when adding LightWidget embed, ensure the iframe includes title="Instagram feed" for screen readers #}
    <div class="rounded-2xl overflow-hidden border border-brand-purple-100 shadow-sm"
         role="region" aria-label="Instagram photo and video feed">
      {{ config.lightwidgetEmbedCode | safe }}
    </div>
  {% else %}
    {# Placeholder shown until the parent adds the LightWidget embed code via CMS #}
    <div class="card text-center py-16 flex flex-col items-center gap-4">
      <p class="text-5xl" aria-hidden="true">📸</p>
      <h2 class="font-display font-bold text-xl text-brand-purple-700">Instagram Feed Coming Soon</h2>
      <p class="text-brand-dark/60 text-sm max-w-sm">
        The video feed is powered by a LightWidget embed.
        Once the embed code is added via the site settings, Maya's performances will appear here.
      </p>
      <a href="{{ config.instagramUrl }}"
         target="_blank"
         rel="noopener noreferrer"
         class="btn-primary mt-2">
        Visit @{{ config.instagramHandle }} on Instagram
      </a>
    </div>
  {% endif %}
</section>

{# ── Instagram CTA ─────────────────────────────────────── #}
<section class="max-w-4xl mx-auto px-4 sm:px-6 mt-6 mb-4 text-center">
  <p class="text-brand-dark/55 text-sm">
    New performances posted regularly on
    <a href="{{ config.instagramUrl }}" target="_blank" rel="noopener noreferrer"
       class="text-brand-teal-400 font-semibold hover:underline">
      @{{ config.instagramHandle }}
    </a>
  </p>
</section>

---
layout: base.njk
title: About
permalink: /about/
---

{# ── Page header ───────────────────────────────────────── #}
<section class="bg-gradient-to-br from-brand-purple-50 to-brand-cream py-12 px-4 sm:px-6 text-center">
  <div class="max-w-2xl mx-auto">
    <p class="text-4xl mb-3" aria-hidden="true">🌟</p>
    <h1 class="font-display font-extrabold text-3xl sm:text-4xl text-brand-purple-700 mb-3">
      About {{ config.name }}
    </h1>
    <p class="text-brand-dark/60 text-base sm:text-lg">
      Getting to know the pianist behind the keys
    </p>
  </div>
</section>

{# ── Bio ───────────────────────────────────────────────── #}
<section class="max-w-2xl mx-auto px-4 sm:px-6 mt-12">
  <div class="card flex flex-col sm:flex-row gap-6 items-start">

    {# Photo placeholder / optional photo #}
    <div class="shrink-0 w-24 h-24 sm:w-32 sm:h-32 rounded-2xl bg-brand-purple-100 flex items-center justify-center text-5xl sm:text-6xl"
         aria-hidden="true">
      🎹
    </div>

    <div>
      <h2 class="font-display font-bold text-xl text-brand-purple-700 mb-2">Hi, I'm {{ config.name }}!</h2>
      <p class="text-brand-dark/75 leading-relaxed">{{ config.bio }}</p>
    </div>
  </div>
</section>

{# ── Fun facts ─────────────────────────────────────────── #}
<section class="max-w-2xl mx-auto px-4 sm:px-6 mt-10">
  <h2 class="section-title">Fun Facts</h2>
  <p class="section-subtitle">A few things to know about {{ config.name }}</p>

  <ul class="grid sm:grid-cols-3 gap-4 list-none" role="list">

    <li class="card text-center flex flex-col items-center gap-2 py-6">
      <span class="text-3xl" aria-hidden="true">🎵</span>
      <span class="text-xs font-semibold text-brand-dark/50 uppercase tracking-wide">Favourite Song</span>
      <span class="font-display font-bold text-brand-dark text-base">{{ config.funFacts.favoriteSong }}</span>
    </li>

    <li class="card text-center flex flex-col items-center gap-2 py-6">
      <span class="text-3xl" aria-hidden="true">🎼</span>
      <span class="text-xs font-semibold text-brand-dark/50 uppercase tracking-wide">Favourite Composer</span>
      <span class="font-display font-bold text-brand-dark text-base">{{ config.funFacts.favoriteComposer }}</span>
    </li>

    <li class="card text-center flex flex-col items-center gap-2 py-6">
      <span class="text-3xl" aria-hidden="true">🍎</span>
      <span class="text-xs font-semibold text-brand-dark/50 uppercase tracking-wide">Practice Snack</span>
      <span class="font-display font-bold text-brand-dark text-base">{{ config.funFacts.practiceSnack }}</span>
    </li>

  </ul>
</section>

{# ── Stats ─────────────────────────────────────────────── #}
<section class="max-w-2xl mx-auto px-4 sm:px-6 mt-10">
  <h2 class="section-title">Journey Stats</h2>
  <p class="section-subtitle">How the practice is going</p>
  {% include "stats-banner.njk" %}
</section>

{# ── CTA ───────────────────────────────────────────────── #}
<section class="max-w-2xl mx-auto px-4 sm:px-6 mt-10 mb-4 text-center">
  <p class="text-brand-dark/60 mb-4">Want to follow along with new milestones?</p>
  <div class="flex flex-wrap gap-3 justify-center">
    <a href="/milestones/" class="btn-primary">View Milestones</a>
    <a href="{{ config.instagramUrl }}" target="_blank" rel="noopener noreferrer" class="btn-secondary">
      Instagram @{{ config.instagramHandle }}
    </a>
  </div>
</section>

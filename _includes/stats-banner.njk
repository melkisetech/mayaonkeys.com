{#
  stats-banner.njk
  Renders the three-stat row: months playing, songs learned, practice days per week.
  Reads from config (passed via base layout / page data).
  The months-playing number is filled client-side by the script in base.njk.
#}
<section class="bg-white border border-brand-purple-100 rounded-2xl shadow-sm overflow-hidden" aria-label="Piano journey stats">
  <ul class="grid grid-cols-3 divide-x divide-brand-purple-100 list-none" role="list">

    <li class="flex flex-col items-center justify-center py-6 px-4 text-center gap-1">
      <span
        class="font-display font-extrabold text-3xl sm:text-4xl text-brand-purple-500"
        data-months-playing="{{ config.startDate }}"
        aria-live="polite"
        aria-label="Months playing (loading)">
        —
      </span>
      <span class="text-xs font-semibold text-brand-dark/50 uppercase tracking-wide">Months Playing</span>
    </li>

    <li class="flex flex-col items-center justify-center py-6 px-4 text-center gap-1">
      <span class="font-display font-extrabold text-3xl sm:text-4xl text-brand-purple-500">
        {{ songs.songs | learnedSongs | length }}
      </span>
      <span class="text-xs font-semibold text-brand-dark/50 uppercase tracking-wide">Songs Learned</span>
    </li>

    <li class="flex flex-col items-center justify-center py-6 px-4 text-center gap-1">
      <span class="font-display font-extrabold text-3xl sm:text-4xl text-brand-purple-500">
        {{ config.practicePerWeek }}
      </span>
      <span class="text-xs font-semibold text-brand-dark/50 uppercase tracking-wide">Days / Week</span>
    </li>

  </ul>
</section>

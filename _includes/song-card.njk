{#
  song-card.njk
  Expected context variable: song (11ty collection item from content/songs/*.md)
  song.data.title, song.data.composer, song.data.status ("learned" | "learning"), song.data.dateLearned
#}
<article class="card flex flex-col gap-2">
  <div class="flex items-start justify-between gap-3">
    <div class="flex-1 min-w-0">
      <h3 class="font-display font-semibold text-brand-dark text-base leading-snug truncate">
        {{ song.data.title }}
      </h3>
      <p class="text-sm text-brand-dark/70 mt-0.5">{{ song.data.composer }}</p>
    </div>
    <span
      class="shrink-0 mt-0.5
        {% if song.data.status == 'learned' %}badge-learned{% else %}badge-learning{% endif %}"
      aria-label="Status: {{ song.data.status }}">
      {% if song.data.status == "learned" %}<span aria-hidden="true">✓</span> Learned{% else %}Learning{% endif %}
    </span>
  </div>

  {% if song.data.dateLearned %}
    <p class="text-xs text-brand-dark/40 font-medium">Learned {{ song.data.dateLearned }}</p>
  {% endif %}
</article>

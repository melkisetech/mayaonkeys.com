{#
  song-card.njk
  Expected context variable: song (11ty collection item from content/songs/*.md)
  song.data.title, song.data.composer, song.data.status ("learned" | "learning"), song.data.dateLearned
  song.data.book (optional), song.data.pageNumber (optional)
#}
<article class="card flex flex-col gap-2">
  <div class="flex items-start justify-between gap-3">
    <div class="flex-1 min-w-0">
      <h3 class="font-display font-semibold text-brand-dark text-base leading-snug truncate">
        {{ song.data.title }}
      </h3>
      {% if song.data.composer %}<p class="text-sm text-brand-dark/70 mt-0.5">{{ song.data.composer }}</p>{% endif %}
    </div>
    <span
      class="shrink-0 mt-0.5
        {% if song.data.status == 'learned' %}badge-learned{% else %}badge-learning{% endif %}"
      aria-label="Status: {{ song.data.status }}">
      {% if song.data.status == "learned" %}<span aria-hidden="true">✓</span> Learned{% else %}Learning{% endif %}
    </span>
  </div>

  {% if song.data.book %}
    <p class="text-xs text-brand-dark/50 leading-snug">
      <span aria-hidden="true">📖</span>
      {{ song.data.book }}{% if song.data.pageNumber %} &middot; p.&nbsp;{{ song.data.pageNumber }}{% endif %}
    </p>
  {% endif %}

  {% if song.data.dateLearned %}
    <p class="text-xs text-brand-dark/40 font-medium">Learned {{ song.data.dateLearned }}</p>
  {% endif %}

  {% if song.data.externalLink %}
    {% set _url = song.data.externalLink | lower %}
    {% if song.data.externalLinkLabel %}
      {% set _label = song.data.externalLinkLabel %}
    {% elif "youtube" in _url or "youtu.be" in _url %}
      {% set _label = "Watch on YouTube" %}
    {% elif "instagram" in _url %}
      {% set _label = "View on Instagram" %}
    {% elif "tiktok" in _url %}
      {% set _label = "View on TikTok" %}
    {% elif "facebook" in _url %}
      {% set _label = "View on Facebook" %}
    {% else %}
      {% set _label = "View link" %}
    {% endif %}
    <a href="{{ song.data.externalLink }}"
       target="_blank"
       rel="noopener noreferrer"
       class="inline-flex items-center gap-1.5 text-sm font-medium text-brand-teal-400 hover:text-brand-teal-500 transition-colors group">
      <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
      </svg>
      <span class="group-hover:underline">{{ _label }}</span>
    </a>
  {% endif %}
</article>

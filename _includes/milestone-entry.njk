{#
  milestone-entry.njk
  Expected context variable: milestone (11ty collection item)
  milestone.data.title, milestone.date, milestone.content (markdown rendered HTML)
#}
<article class="milestone-entry relative pl-4 sm:pl-8">
  {# Timeline connector line #}
  <div class="absolute left-2.5 top-4 bottom-0 w-0.5 bg-brand-purple-100 last:hidden" aria-hidden="true"></div>

  {# Timeline dot #}
  <div class="absolute left-0 top-3 w-5 h-5 rounded-full bg-brand-purple-200 border-2 border-brand-purple-400 flex items-center justify-center" aria-hidden="true">
    <div class="w-2 h-2 rounded-full bg-brand-purple-500"></div>
  </div>

  <div class="card ml-2">
    <time
      class="text-xs font-semibold text-brand-teal-400 uppercase tracking-wide"
      datetime="{{ milestone.date | htmlDateString }}">
      {{ milestone.date | dateDisplay }}
    </time>
    <h3 class="font-display font-bold text-brand-dark text-lg mt-1 mb-2">
      {{ milestone.data.title }}
    </h3>
    <div class="flex gap-4">
      {% if milestone.data.image %}
        <button
          type="button"
          class="shrink-0 cursor-zoom-in rounded-xl focus:outline-none focus:ring-2 focus:ring-brand-purple-400 focus:ring-offset-2"
          data-lightbox-src="{{ milestone.data.image }}"
          data-lightbox-alt="{{ milestone.data.imageAlt if milestone.data.imageAlt else milestone.data.title }}"
          aria-label="View full image: {{ milestone.data.imageAlt if milestone.data.imageAlt else milestone.data.title }}">
          <img
            src="{{ milestone.data.image }}"
            alt="{{ milestone.data.imageAlt if milestone.data.imageAlt else milestone.data.title }}"
            class="w-28 h-28 sm:w-36 sm:h-36 object-cover rounded-xl"
            loading="lazy">
        </button>
      {% endif %}
      <div class="prose prose-sm prose-stone max-w-none text-brand-dark/75
                  prose-a:text-brand-teal-400 prose-a:no-underline hover:prose-a:underline">
        {{ milestone.content | safe }}
      </div>
    </div>
    {% if milestone.data.externalLink %}
      {% set _url = milestone.data.externalLink | lower %}
      {% if milestone.data.externalLinkLabel %}
        {% set _label = milestone.data.externalLinkLabel %}
      {% elif "youtube" in _url or "youtu.be" in _url %}
        {% set _label = "Watch on YouTube" %}
      {% elif "instagram" in _url %}
        {% set _label = "View on Instagram" %}
      {% elif "tiktok" in _url %}
        {% set _label = "View on TikTok" %}
      {% elif "facebook" in _url %}
        {% set _label = "View on Facebook" %}
      {% else %}
        {% set _label = "View link" %}
      {% endif %}
      <div class="mt-3">
        <a href="{{ milestone.data.externalLink }}"
           target="_blank"
           rel="noopener noreferrer"
           class="inline-flex items-center gap-1.5 text-sm font-medium text-brand-teal-400 hover:text-brand-teal-500 transition-colors group">
          <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
          </svg>
          <span class="group-hover:underline">{{ _label }}</span>
        </a>
      </div>
    {% endif %}
  </div>
</article>

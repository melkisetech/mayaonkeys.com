{#
  milestone-entry.njk
  Expected context variable: milestone (11ty collection item)
  milestone.data.title, milestone.date, milestone.content (markdown rendered HTML)
#}
<article class="relative pl-4 sm:pl-8 pb-10 last:pb-0">
  {# Timeline connector line #}
  <div class="absolute left-2.5 top-4 bottom-0 w-0.5 bg-brand-purple-100 last:hidden" aria-hidden="true"></div>

  {# Timeline dot #}
  <div class="absolute left-0 top-3 w-5 h-5 rounded-full bg-brand-purple-200 border-2 border-brand-purple-400 flex items-center justify-center" aria-hidden="true">
    <div class="w-2 h-2 rounded-full bg-brand-purple-500"></div>
  </div>

  <div class="card ml-2">
    <time
      class="text-xs font-semibold text-brand-teal-400 uppercase tracking-wide"
      datetime="{{ milestone.date | htmlDateString }}">
      {{ milestone.date | dateDisplay }}
    </time>
    <h3 class="font-display font-bold text-brand-dark text-lg mt-1 mb-2">
      {{ milestone.data.title }}
    </h3>
    {% if milestone.data.image %}
      <img
        src="{{ milestone.data.image }}"
        alt="{{ milestone.data.imageAlt if milestone.data.imageAlt else milestone.data.title }}"
        class="w-full aspect-video object-cover rounded-xl mb-3"
        loading="lazy">
    {% endif %}
    <div class="prose prose-sm prose-stone max-w-none text-brand-dark/75
                prose-a:text-brand-teal-400 prose-a:no-underline hover:prose-a:underline">
      {{ milestone.content | safe }}
    </div>
  </div>
</article>
